    "1":  {"file": "SDD/01-executive-summary.md", "title": "Executive Summary"},
    "2":  {"file": "SDD/02-business-direction.md", "title": "Business Direction"},
    "3":  {"file": "SDD/03-project-definition.md", "title": "Project Definition (scope, success criteria SC1-SC9)"},
    "4":  {"file": "SDD/04-system-context.md", "title": "System Context (actors, interfaces, data flows)"},
    "5":  {"file": "SDD/05-non-functional-requirements.md", "title": "Non-Functional Requirements (NFR-001…065)"},
    "6":  {"file": "SDD/06-use-case-model.md", "title": "Use Case Model (UC-001…008)"},
    "7":  {"file": "SDD/07-subject-area-model.md", "title": "Subject Area Model (entities, state ownership)"},
    "8":  {"file": "SDD/08-architecture-decisions.md", "title": "Architecture Decisions (AD-001…015)"},
    "9":  {"file": "SDD/09-architecture-overview.md", "title": "Architecture Overview (pipelines, polling, broadcasting)"},
    "10": {"file": "SDD/10-service-model.md", "title": "Service Model (WS/REST command contract)"},
    "11": {"file": "SDD/11-component-model.md", "title": "Component Model"},
    "12": {"file": "SDD/12-operational-model.md", "title": "Operational Model (deploy, config, troubleshooting)"},
    "13": {"file": "SDD/13-feasibility-assessment.md", "title": "Feasibility Assessment (risks R1-R8, assumptions A1-A6, issues I1-I7)"},
    "14": {"file": "SDD/14-version-history.md", "title": "Version History"},
    "15": {"file": "SDD/15-ptt-safety-architecture.md", "title": "PTT Safety Architecture"}
  },
