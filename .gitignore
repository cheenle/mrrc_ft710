# OS
.DS_Store
Thumbs.db

# Sensitive config (uncomment if needed)
# config_local.py
.env
.env.example

# SSL certificates (contain private keys — do not commit)
# No trailing slash: also ignores the `certs` symlink (-> external dir).
certs
certs/

# Personal iOS signing overrides (Team ID, bundle ID) — never commit someone
# else's identifiers alongside the shared project.yml.
FT710Mobile/project.local.yml

# Generated by `xcodegen generate` from project.yml/project.local.yml — never
# commit so personal signing values (Team ID, bundle ID) can't leak in.
FT710Mobile/FT710Mobile.xcodeproj/
FT710Mobile/SunsdrMobile.xcodeproj/
